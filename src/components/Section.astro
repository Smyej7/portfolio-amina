---
interface Props {
  text: string;
  href: string;
  translationKey?: string;
}

const { text, href, translationKey } = Astro.props;
---

<section id={href} class="py-24">
  <h2
    class="mb-14 font-serif text-4xl font-bold tracking-tighter md:text-5xl"
    style="color: var(--text-primary);"
    data-i18n={translationKey}
  >
    {text}
  </h2>
  <slot />
</section>
