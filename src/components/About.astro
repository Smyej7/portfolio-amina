---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import { getTranslations } from "@/i18n/translations";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
const t = getTranslations("fr");
const formattedDescription = t.about.description.replace(/\n/g, "<br>");
---

<Section text="À propos de moi" href="about" translationKey="sections.about">
  <div class="flex flex-col items-center gap-12 md:flex-row md:gap-8">
    <p
      class="w-auto text-base md:pr-5"
      style="color: var(--text-secondary);"
      data-i18n-html="about.description"
      set:html={formattedDescription}
    />
    <div
      class="h-80 w-64 flex-shrink-0 rotate-[5deg] bg-white p-4 md:rotate-[7deg]"
    >
      <Image
        class="object-cover"
        src={image}
        width="260"
        height="260"
        alt={name}
      />
    </div>
  </div>
</Section>
